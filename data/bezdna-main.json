  "dialogs": {
    "q_arrival": [
      {
        "speaker": "Страж ворот",
        "text": "Имя? Место? Кто подтвердит, что ты существовал до этой дороги?",
        "choices": [
          {
            "text": "Каэл Ринн. Хольмовые Дворы. Мой брат — Эдан Ринн.",
            "target": 1,
            "sets": "kael_registered"
          },
          {
            "text": "Почему в Вард-Элене всё надо записывать?",
            "target": 2
          }
        ]
      },
      {
        "speaker": "Страж ворот",
        "text": "Эдан Ринн. Отряд Марры Соль. Срок возврата прошёл. Войдёшь как родственник пропавшего, не как экспедитор.",
        "choices": [
          {
            "text": "Где искать запись о нём?",
            "target": 3
          }
        ]
      },
      {
        "speaker": "Страж ворот",
        "text": "Потому что здесь даже петух входит через ворота с именем. А вещи без записи иногда открывают двери сами.",
        "choices": [
          {
            "text": "Тогда запишите меня правильно.",
            "target": 1,
            "sets": "kael_registered"
          }
        ]
      },
      {
        "speaker": "Страж ворот",
        "text": "Дом поминовения — через площадь. Если пришёл искать правду, найми ещё и печатника.",
        "choices": [
          {
            "text": "Перейти к Дому поминовения",
            "next": "q_memorial"
          }
        ]
      }
    ],
    "q_memorial": [
      {
        "speaker": "Ольма",
        "text": "Живой, мёртвый, пропавший, удерживаемый или спорный?",
        "choices": [
          {
            "text": "Пропавший. Эдан Ринн. Мой брат.",
            "target": 1,
            "sets": "edan_not_dead_status"
          },
          {
            "text": "Что значит спорный?",
            "target": 2
          }
        ]
      },
      {
        "speaker": "Ольма",
        "text": "Статус: не вернулся. Не мёртвый. Не удерживаемый. Не спорный. Пока.",
        "choices": [
          {
            "text": "Где найти Марру Соль?",
            "target": 3
          }
        ]
      },
      {
        "speaker": "Ольма",
        "text": "Когда тело, имя и память расходятся, город спорит с Бездной о том, кого считать человеком.",
        "choices": [
          {
            "text": "Тогда найдите строку Эдана.",
            "target": 1,
            "sets": "edan_not_dead_status"
          }
        ]
      },
      {
        "speaker": "Ольма",
        "text": "Если Марра вернулась, ищи в Последней ступени. Но дай ей закончить чашку.",
        "choices": [
          {
            "text": "Перейти к Марре",
            "next": "q_marra"
          }
        ]
      }
    ],
    "q_marra": [
      {
        "speaker": "Марра Соль",
        "text": "Сегодня я не Марра Соль. Сегодня я человек, который ещё не допил.",
        "choices": [
          {
            "text": "Я брат Эдана Ринна.",
            "target": 1,
            "sets": "met_marra"
          },
          {
            "text": "Ты его бросила.",
            "target": 2,
            "sets": "marra_angry"
          }
        ]
      },
      {
        "speaker": "Марра Соль",
        "text": "Щепки? Последний раз, когда я видела твоего брата, он был жив.",
        "choices": [
          {
            "text": "Почему он не вернулся?",
            "target": 3,
            "sets": "edan_held_door"
          },
          {
            "text": "Я хочу нанять тебя.",
            "target": 4
          }
        ]
      },
      {
        "speaker": "Марра Соль",
        "text": "Я вывела троих. Если бы открыла дверь, ты бы говорил не со мной, а с тем, что носит моё лицо.",
        "choices": [
          {
            "text": "Прости. Расскажи про Эдана.",
            "target": 1
          }
        ]
      },
      {
        "speaker": "Марра Соль",
        "text": "Потому что кто-то должен был держать дверь. И потому что внизу двери редко объясняют честно.",
        "choices": [
          {
            "text": "Что мне делать дальше?",
            "target": 4
          }
        ]
      },
      {
        "speaker": "Марра Соль",
        "text": "Утром тебя начнут покупать: Контора, реликварии, посредники. Сначала узнай, какая строка держит твой дом.",
        "choices": [
          {
            "text": "Идти в Контору Медного Порога",
            "next": "q_debt"
          }
        ]
      }
    ],
    "q_debt": [
      {
        "speaker": "Лорн Вейк",
        "text": "Вам нужен не контракт. Вам нужен способ выплатить долг.",
        "choices": [
          {
            "text": "Мне нужна правда.",
            "target": 1
          },
          {
            "text": "Покажите подпись Эдана.",
            "target": 2
          }
        ]
      },
      {
        "speaker": "Лорн Вейк",
        "text": "Правда редко продаётся отдельно. Обычно идёт вместе с расходами.",
        "choices": [
          {
            "text": "Какие есть пути?",
